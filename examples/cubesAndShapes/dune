(rule
 (target cubesAndShapes_x11.ml)
 (action (write-file %{target} "include CubesAndShapes")))

(rule
 (target cubesAndShapes_wayland.ml)
 (action (write-file %{target} "include CubesAndShapes")))

(rule
 (target ellipsoid.ml)
 (deps shaders/ellipsoid.glsl)
 (action
  (with-stdout-to %{target}
   (run glsl_to_ml %{deps}))))

