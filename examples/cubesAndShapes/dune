(executable
 (name cubesAndShapes_x11)
 (public_name cubesAndShapes_x11)
 (modules cubesAndShapes_x11 cubesAndShapes ellipsoid  fragment_implicit_shadow  fragment_light_implicit_with_shadow  fragment_light_with_shadow  fragment_shadow  solve  vertex_implicit_shadow  vertex_light_with_shadow  vertex_shadow  )
