(rule
 (target spheres_x11.ml)
 (action (write-file %{target} "include Spheres")))

(rule
 (target spheres_wayland.ml)
 (action (write-file %{target} "include Spheres")))

(rule
 (target fragment_implicit_shadow.ml)
 (deps shaders/fragment_implicit_shadow.glsl)
 (action
  (with-stdout-to %{target}
   (run glsl_to_ml %{deps}))))

